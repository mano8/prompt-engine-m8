# Copy to media.env and replace every "changethis" with real values.
# Token verification uses JWKS — no private key or ACCESS_SECRET_KEY needed.

# Docker/K8s secret files: inherited from auth-sdk-m8 CommonSettings.
# For any secret field, set <FIELD>_FILE=/run/secrets/<name> instead of putting
# the plaintext value in this env file (for example DB_PASSWORD_FILE).
# The pointed file is stripped and used as the field value; missing files fail closed.

# ── Identity ──────────────────────────────────────────────────────────────────
DOMAIN=localhost
ENVIRONMENT=local
PROJECT_NAME=M8MediaService
STACK_NAME=m8-media-service

# ── API & docs ────────────────────────────────────────────────────────────────
API_PREFIX=/media
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true

# ── CORS / Frontend ───────────────────────────────────────────────────────────
BACKEND_HOST=http://127.0.0.1:9000
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:9000,https://localhost,https://localhost:9000,https://localhost:5173

# ── Host header allowlist (auth-sdk-m8 >= 1.2) ───────────────────────────────
# Optional in local/dev. Set in production/strict mode to enable
# TrustedHostMiddleware and reject unexpected Host headers. Include every host
# used through Traefik plus Docker DNS names used by in-cluster callers.
#ALLOWED_HOSTS=localhost,127.0.0.1,media_service

# ── Service role & auth routing ───────────────────────────────────────────────
AUTH_SERVICE_ROLE=consumer
AUTH_PREFIX=/user

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# DB_USER must match MEDIA_DB_USER in .env; DB_PASSWORD must match MEDIA_DB_PASSWORD.
SELECTED_DB=Postgres
DB_HOST=m8_db
DB_PORT=5432
DB_DATABASE=media_db
DB_USER=changethis
# Password: >= 8 chars, with upper, lower, digit, and special char (no spaces).
DB_PASSWORD=changethis

# ── Media Redis (MinIO presign cache) ────────────────────────────────────────
MEDIA_REDIS_HOST=media_redis_cache
MEDIA_REDIS_PORT=6379
MEDIA_REDIS_USER=media
# Password: >= 8 chars, with upper, lower, digit, and special char (no spaces).
MEDIA_REDIS_PASSWORD=changethis
MEDIA_REDIS_NAMESPACE=media

# ── Internal service auth ─────────────────────────────────────────────────────
# Shared bearer token the media-worker presents on internal callbacks
# (scan-result, variant register/job-status). Use a long, high-entropy random
# value (>= 32 chars); must match the worker's MEDIA_INTERNAL_SERVICE_TOKEN.
MEDIA_INTERNAL_SERVICE_TOKEN=changethis

# ── Share links ───────────────────────────────────────────────────────────────
# Independent HMAC key for signing share-link tokens — media-service-owned, NOT
# an auth secret. Use a long, high-entropy random value (>= 32 chars); rotating
# it invalidates every outstanding share link.
# In staging/prod this MUST come from secrets management, never a committed
# runtime env file; a literal value here is only acceptable for local/dev.
MEDIA_SHARE_SIGNING_SECRET=changethis
# Share-link lifetime bounds (seconds). The caller picks expires_in per link;
# omitting it falls back to the default, and any value above the max is rejected.
MEDIA_SHARE_DEFAULT_EXPIRES_SECONDS=604800
MEDIA_SHARE_MAX_EXPIRES_SECONDS=2592000

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_REGION=eu-west-1
# MinIO credentials: access key >= 3 chars, secret key >= 8 chars.
# Use `media_rw_user` as the access key.
MINIO_ACCESS_KEY=changethis
MINIO_SECRET_KEY=changethis
MINIO_BUCKET_PUBLIC=public-media
MINIO_BUCKET_PRIVATE=private-media
MINIO_BUCKET_SENSITIVE=sensitive-media
MINIO_BUCKET_TEMP=temp-media
MINIO_BUCKET_ARCHIVE=archive-media
MINIO_PRESIGNED_URL_EXPIRE_SECONDS=300
MEDIA_MAX_UPLOAD_SIZE_BYTES=104857600
# Optional per-category overrides of the global max (bytes), as a JSON object
# keyed by category; a category absent here falls back to the global value above.
# MEDIA_MAX_UPLOAD_SIZE_BYTES_PER_CATEGORY={"image": 52428800, "video": 524288000}
MINIO_PUBLIC_ENDPOINT=http://127.0.0.1:9005

# ── SHA-256 upload verification ───────────────────────────────────────────────
# When a client sends an expected SHA-256 on complete, the object is streamed
# from storage and hashed in chunks of this many bytes, so a large (size-capped)
# object is never buffered whole in memory. Defaults below; uncomment to tune.
# MEDIA_SHA256_VERIFY_CHUNK_SIZE=1048576
# Process-wide ceiling on concurrent SHA-256 verifications (bounds simultaneous
# streamed reads). Default 4.
# MEDIA_SHA256_VERIFY_MAX_CONCURRENCY=4

# ── Storage quotas ───────────────────────────────────────────────────────────
# Default per-owner ceilings, enforced at upload initiation. Leave unset for
# unlimited; admins can raise/lower a single scope via PUT /v1/admin/quotas/{id}.
# MEDIA_DEFAULT_QUOTA_BYTES=10737418240
# MEDIA_DEFAULT_QUOTA_OBJECTS=10000

# ── Lifecycle / retention (service-owned maintenance worker) ──────────────────
# Drives the scheduled hard-purge, stale-upload expiry and orphan reconciliation
# run by the media_service_worker container. Not secrets — literal values.
# Age (days) a soft-deleted object must exceed before its bytes + row are purged.
MEDIA_RETENTION_PURGE_DAYS=30
# Max objects hard-purged per run (bounds blast radius).
MEDIA_PURGE_BATCH_LIMIT=500
# Safety window (minutes): objects/keys younger than this are never flagged
# orphan, so an in-flight upload is never reconciled away.
MEDIA_RECONCILE_GRACE_MINUTES=60
MEDIA_RECONCILE_BATCH_LIMIT=1000
# Cron cadence: hard-purge runs daily at this hour; stale-upload expiry runs
# hourly at this minute.
MEDIA_PURGE_CRON_HOUR=3
MEDIA_STALE_CRON_MINUTE=15

# ── Token verification — RS256 via JWKS ──────────────────────────────────────
ACCESS_TOKEN_ALGORITHM=RS256
JWKS_URI=http://auth_user_service:8000/user/.well-known/jwks.json
JWKS_CACHE_TTL_SECONDS=300
REFRESH_SECRET_KEY=changethis
REFRESH_TOKEN_ALGORITHM=HS256
TOKEN_MODE=stateful
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# ── Token boundary claims — REQUIRED under secure-by-default ──────────────────
# auth-sdk-m8 >= 1.0.0 turns TOKEN_STRICT_VALIDATION on by default: this consumer
# fails closed at boot unless both are set, and rejects tokens whose iss/aud claim
# differs. Must match auth_user_service TOKEN_ISSUER / TOKEN_AUDIENCE exactly.
# Opt out (legacy/local only) with TOKEN_STRICT_VALIDATION=false.
TOKEN_ISSUER=https://auth.example.com
TOKEN_AUDIENCE=https://media.example.com

# ── Token revocation (stateful consumer) ─────────────────────────────────────
INTROSPECTION_URL=http://auth_user_service:8000/user/private/v1/jti-status
# Shared or per-consumer bootstrap secret for introspection calls to fa-auth.
# Legacy mode (INTERNAL_CLIENT_ID unset): sent as X-Internal-Token and must
# match PRIVATE_API_SECRET in auth.env. Per-consumer mode (below): this is the
# bootstrap credential registered under INTERNAL_CLIENT_ID in the issuer's
# PRIVATE_API_CONSUMERS registry. >= 32 chars, upper+lower+digit+special.
PRIVATE_API_SECRET=changethis
# Fail-closed (default): 503 when introspection is unavailable, preventing
# potentially-revoked tokens from passing. Set fail_open to accept tokens
# during outages (availability-first); the opt-out is logged loudly and
# counted (revocation_check_failures_total{mode="fail_open"}) — item 5.5.
# Recommended: fail_closed in production (set in hardened media.env.example).
# ACCESS_REVOCATION_FAILURE_MODE=fail_closed

# ── Per-consumer internal auth (9.1 — fastapi-m8 >= 3.1.0) ──────────────────
# Switch from the legacy single-secret model to per-consumer credentials.
# When set, PRIVATE_API_SECRET is this consumer's per-consumer bootstrap
# secret; the issuer gate is scoped to the registered PRIVATE_API_CONSUMERS
# entry. Unset (default) → legacy X-Internal-Token mode (single PRIVATE_API_SECRET).
INTERNAL_CLIENT_ID=media-service
# Optional: exchange the bootstrap credential for short-TTL Bearer service tokens
# at {issuer}/private/v1/service-token (requires fa-auth-m8 9.1 issuer side).
# SERVICE_TOKEN_EXCHANGE_ENABLED=false

# ── Event signing — auth-sdk-m8 1.0.0 boot validator (fail-closed when enabled) ──
# Must match EVENT_SIGNING_KEY in auth.env.
EVENT_SIGNING_ENABLED=true
EVENT_SIGNING_KEY=changethis

# ── Auth event stream (fa-auth SSE bridge — fastapi-m8 >= 1.5.0) ──────────────
# Streams session-revoked / user-deleted events from fa-auth to evict the
# REVOCATION_CACHE_TTL_SECONDS positive-validation cache early.
# Stream URL is derived from INTROSPECTION_URL — no extra URL needed.
# Set REVOCATION_CACHE_TTL_SECONDS > 0 to enable the local cache; set to 0
# (default) to skip caching and always call fa-auth on each request.
REVOCATION_CACHE_TTL_SECONDS=30
# EVENT_STREAM_CONNECT_TIMEOUT=5.0
# EVENT_STREAM_READ_TIMEOUT=60.0

# ── Response security headers (auth-sdk-m8 >= 1.2.1, three tiers) ─────────────
# Tier 1 (X-Content-Type-Options, X-Frame-Options) is always on; tier 2
# (Referrer-Policy, Permissions-Policy) applies on the production gate. Tier 3
# below is browser-persisted and hard to reverse (HSTS poisons a host's HTTPS
# cache for its full max-age), so it is express opt-in, defaults to off, and is
# NEVER emitted on a local stack even when enabled. Enable only on a
# TLS-terminated public host. Traefik also emits its own headers (see
# traefik/dynamic_conf.yml security-headers middleware) — keep the two in sync.
#HSTS_ENABLED=false
#CONTENT_SECURITY_POLICY_ENABLED=false
#HSTS_MAX_AGE=31536000
#HSTS_INCLUDE_SUBDOMAINS=true
#CONTENT_SECURITY_POLICY=

# ── Rate-limiter Redis-error policy ──────────────────────────────────────────
# Controls behaviour when the rate-limiter Redis is unreachable.
# fail_open (default): traffic passes through; limits are unenforced during outages.
# fail_closed: returns 503 on Redis error; prevents unenforced bursts.
# Recommended: fail_closed in production (set in hardened media.env.example).
# MEDIA_RATE_LIMIT_FAILURE_MODE=fail_open

# ── Events / outbox webhook delivery (Phase 16) ───────────────────────────────
# Tunables for the media_service_worker container's deliver_outbox cron, which
# drains PENDING outbox rows and POSTs each as a signed OutboxEventPayload to
# matching subscribers. Not secrets — a subscription's signing secret is stored
# per-row (created via POST /v1/admin/subscriptions), never set here.
# OUTBOX_DELIVERY_CRON_SECOND=0          # second-of-minute the cron fires (runs once/min)
# OUTBOX_BATCH_LIMIT=100                 # max events claimed per run
# OUTBOX_MAX_ATTEMPTS=8                  # poison-message cap → terminal FAILED
# OUTBOX_BACKOFF_BASE_SECONDS=30         # retry delay = base * 2**(attempts-1)
# OUTBOX_DELIVERY_TIMEOUT_SECONDS=10.0   # per-subscriber POST timeout

# ── Outbound webhook SSRF guard (core.ssrf) ──────────────────────────────────
# A subscriber URL is re-resolved and every IP checked before each delivery POST.
# Loopback/link-local/metadata are always blocked; private (RFC1918/ULA/CGNAT)
# targets and plain http:// are allowed in local/dev but rejected under
# production/strict. Exempt a trusted in-cluster subscriber by exact hostname
# (comma-separated) — needed only when production must reach an internal target:
# MEDIA_WEBHOOK_ALLOWED_INTERNAL_HOSTS=["media_worker"]

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_GROUPS=all

# Optional bearer credential for /metrics. Leave unset to rely on the internal
# network boundary; if set, configure Prometheus to send the same bearer token.
#METRICS_SCRAPE_CREDENTIAL=changethis

# ── Health detail gating (item 9.3) ──────────────────────────────────────────
# Dedicated credential for the deep-/health detail body gate (X-Internal-Token).
# Unset (default) = detail body never shown — only {"status": "ok/fail"} is
# returned to unauthenticated callers (fail-closed). Set to a long-lived secret
# and present it as X-Internal-Token to receive the full per-check breakdown.
# MUST NOT equal PRIVATE_API_SECRET — a fatal startup error is raised on reuse.
# Supports _FILE mount: HEALTH_DETAIL_CREDENTIAL_FILE=/run/secrets/health_detail_credential
#HEALTH_DETAIL_CREDENTIAL=changethis
