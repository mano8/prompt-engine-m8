# Compose env for media-worker-m8. Copy to `worker.env` and fill real values.
# Secrets MUST stay the literal `changethis` here (fail-closed); set strong
# values only in the real `worker.env`. These MUST match the dev media stack
# (media.env): same MinIO creds, same MEDIA_REDIS_PASSWORD, and the same
# MEDIA_INTERNAL_SERVICE_TOKEN as media-service.

# ── Media-service internal API ───────────────────────────────────────────────
# In-cluster URL including the API prefix; the worker appends /v1/internal/...
MEDIA_API_URL=http://media_service:8000/media
# Shared bearer token for media-service ↔ media-worker internal callbacks.
# Must match media-service's MEDIA_INTERNAL_SERVICE_TOKEN.
MEDIA_INTERNAL_SERVICE_TOKEN=changethis

# ── Media Redis (ARQ queue) ──────────────────────────────────────────────────
MEDIA_REDIS_HOST=media_redis_cache
MEDIA_REDIS_PORT=6379
MEDIA_REDIS_USER=media
MEDIA_REDIS_PASSWORD=changethis
MEDIA_REDIS_NAMESPACE=media

# ── MinIO / object storage ───────────────────────────────────────────────────
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_REGION=eu-west-1
# Use `media_rw_user` as the access key.
MINIO_ACCESS_KEY=changethis
MINIO_SECRET_KEY=changethis

# ── ClamAV daemon ────────────────────────────────────────────────────────────
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
