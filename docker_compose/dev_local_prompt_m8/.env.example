# Copy to .env — Docker Compose infrastructure variables.
# Application settings go in auth.env and media.env (see *.example files there).
# Generate passwords: python -c "import secrets; print(secrets.token_urlsafe(32))"

# ── Optional: Traefik port binding ───────────────────────────────────────────
# Default 127.0.0.1 (localhost only). Set to 0.0.0.0 to expose on the LAN.
#API_BIND_IP=127.0.0.1

# ── PostgreSQL superuser (engine bootstrap) ───────────────────────────────────
# Used by the postgres container itself + init-db.sh to create per-service users.
# Do not use these credentials in auth.env / api.env — services get their own users.
DB_USER=m8_admin
DB_PASSWORD=changethis
DB_PORT=5432

# ── DB isolation: choose ONE model, comment out the others ───────────────────
#
# SCENARIO 1 — single shared database
#   All services share one DB and one user. Simplest setup; no data isolation.
#
# DB_USER=myuser
# DB_PASSWORD=changethis
# DB_NAME=myapp
#
# SCENARIO 2 — per-service isolation (default for this stack)
#   init-db.sh creates a separate DB + user per service on first volume init.
#   Prefix rules: UPPERCASE, starts with a letter, chars [A-Z0-9_].
#   Each *_DB_PASSWORD is validated by the consuming service: >= 8 chars, with
#   upper, lower, digit, and special char (no spaces).
#
# Distinct per-service DB users, e.g. `auth_user` and `media_user`.
AUTH_DB_USER=changethis
AUTH_DB_PASSWORD=changethis
AUTH_DB_NAME=auth_db

MEDIA_DB_USER=changethis
MEDIA_DB_PASSWORD=changethis
MEDIA_DB_NAME=media_db
#
# SCENARIO 3 — arbitrary N-service isolation
#   Add any PREFIX_DB_{USER,PASSWORD,NAME} triplet. No compose edits needed.
#
# WORKER_DB_USER=worker_user
# WORKER_DB_PASSWORD=changethis
# WORKER_DB_NAME=worker_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Passwords: >= 8 chars, with upper, lower, digit, and special char (no spaces).
REDIS_PASSWORD=changethis
MEDIA_REDIS_PASSWORD=changethis

# ── MinIO ─────────────────────────────────────────────────────────────────────
# Root user >= 3 chars; root password >= 8 chars. Root user e.g. `minio_user`.
MINIO_ROOT_USER=changethis
MINIO_ROOT_PASSWORD=changethis

# ── Secrets & CI ──────────────────────────────────────────────────────────────
# .env must be fully written BEFORE 'docker compose up' on first boot.
# init-db.sh runs once at volume creation — changes to .env do not reprovision.
# To reprovision after config changes: bash init.sh --reset-db
#
# CI integration tests (clean state between runs):
#   bash init.sh --reset-db --yes && docker compose up -d --build
