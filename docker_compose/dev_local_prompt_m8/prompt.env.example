# prompt_engine_service runtime config (fastapi-m8 3.3.0 consumer / auth-sdk-m8 2.1.1).
# Copy to prompt.env, then replace every `changethis` before starting the stack.
# Every key below is a field of ConsumerServiceSettings (fastapi-m8) or an
# inherited auth-sdk-m8 CommonSettings field. The Settings model uses
# extra="forbid": an unknown key here fails the service at boot.
#
# Docker/K8s secret files: for any secret field, set <FIELD>_FILE=/run/secrets/<name>
# instead of the plaintext value (e.g. DB_PASSWORD_FILE). The pointed file is
# stripped and used as the value; a missing file fails closed.

# ── Identity ──────────────────────────────────────────────────────────────────
DOMAIN=localhost
ENVIRONMENT=local              # local | development | staging | production
PROJECT_NAME=M8PromptEngineService
STACK_NAME=m8-prompt-engine-service

# ── API & docs ────────────────────────────────────────────────────────────────
API_PREFIX=/prompt             # public route prefix (Traefik → /prompt/*)
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true

# ── CORS / Frontend ───────────────────────────────────────────────────────────
BACKEND_HOST=http://127.0.0.1:9000
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:4321,http://localhost:5173,http://localhost:9000,https://localhost:4430

# ── Host header allowlist (auth-sdk-m8 TrustedHostMiddleware) ─────────────────
# Optional in local/dev (unset = middleware not registered). Set in
# production/strict to reject unexpected Host headers. Include every host reached
# through Traefik plus the Docker DNS names in-cluster callers use.
#ALLOWED_HOSTS=localhost,127.0.0.1,prompt_engine_service

# ── Service role & auth routing ───────────────────────────────────────────────
AUTH_SERVICE_ROLE=consumer     # always "consumer" for a fastapi-m8 service
AUTH_PREFIX=/user              # base path of the fa-auth issuer in this stack

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# DB_USER must match PROMPT_DB_USER in .env, DB_PASSWORD must match
# PROMPT_DB_PASSWORD, and DB_DATABASE must match PROMPT_DB_NAME — init-db.sh
# provisions this user/database from the .env triplet on first volume init.
SELECTED_DB=Postgres
DB_HOST=m8_db
DB_PORT=5432
DB_DATABASE=prompt_engine_db
DB_USER=changethis
DB_PASSWORD=changethis

# ── Token verification — RS256 via JWKS ──────────────────────────────────────
# Consumers only validate tokens: no private key or ACCESS_SECRET_KEY needed.
ACCESS_TOKEN_ALGORITHM=RS256
JWKS_URI=http://auth_user_service:8000/user/.well-known/jwks.json
JWKS_CACHE_TTL_SECONDS=300
# Refresh tokens are internal and always HS256; the consumer issues none, but
# REFRESH_SECRET_KEY is a required CommonSettings field.
REFRESH_SECRET_KEY=changethis
REFRESH_TOKEN_ALGORITHM=HS256
TOKEN_MODE=stateful            # must match the auth issuer's TOKEN_MODE
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# ── Token boundary claims — REQUIRED under secure-by-default ──────────────────
# auth-sdk-m8 keeps TOKEN_STRICT_VALIDATION on by default: this consumer fails
# closed at boot unless both are set, and rejects tokens whose iss/aud claim
# differs. In this combined stack a single fa-auth issuer stamps ONE audience
# shared by every consumer, so TOKEN_AUDIENCE must equal auth.env's
# TOKEN_AUDIENCE exactly (and TOKEN_ISSUER must match its TOKEN_ISSUER).
# Opt out for local-only experiments with TOKEN_STRICT_VALIDATION=false.
TOKEN_ISSUER=https://auth.example.com
TOKEN_AUDIENCE=https://media.example.com

# ── Token revocation (stateful mode) — auth private API ───────────────────────
INTROSPECTION_URL=http://auth_user_service:8000/user/private/v1/jti-status
PRIVATE_API_SECRET=changethis
# Per-consumer internal auth (fastapi-m8 item 9.1): identifies this consumer to
# the issuer. PRIVATE_API_SECRET becomes this consumer's bootstrap credential,
# and the issuer must register this id in PRIVATE_API_CONSUMERS (auth.env) with
# the same secret. Required in production/strict; legacy shared-secret mode
# (this unset) is development-only.
INTERNAL_CLIENT_ID=prompt-engine-service

# ── Auth event stream (fa-auth SSE bridge) + revocation cache ─────────────────
# The stream consumes session-revoked / user-deleted events to evict the
# positive-validation cache early. The stream URL is derived from
# INTROSPECTION_URL. Set the TTL > 0 to enable the cache the stream evicts;
# 0 makes the stream a no-op.
REVOCATION_CACHE_TTL_SECONDS=30
#EVENT_STREAM_CONNECT_TIMEOUT=5.0     # seconds to wait for initial connection
#EVENT_STREAM_READ_TIMEOUT=60.0       # seconds between SSE frames (> fa-auth heartbeat)

# ── Event signing — boot validator (fail-closed when enabled) ─────────────────
# EVENT_SIGNING_ENABLED defaults true; boot fails closed without a strong key.
# Use the SAME EVENT_SIGNING_KEY here and in auth.env for this stack.
EVENT_SIGNING_ENABLED=true
EVENT_SIGNING_KEY=changethis

# ── Revocation failure mode (consumer) ───────────────────────────────────────
# Behaviour when the fa-auth introspection call fails.
# fail_closed (default, secure): reject the request. fail_open: allow through
# (availability over strictness; each swallowed failure is logged + counted).
#ACCESS_REVOCATION_FAILURE_MODE=fail_closed

# ── Response security headers (three tiers) ───────────────────────────────────
# Tier 1 (X-Content-Type-Options, X-Frame-Options) is always on; tier 2
# (Referrer-Policy, Permissions-Policy) applies on the production gate. Tier 3
# below is browser-persisted and hard to reverse (HSTS poisons a host's HTTPS
# cache for its full max-age), so it is express opt-in, defaults off, and is
# NEVER emitted on a local stack even when enabled. Enable only on a
# TLS-terminated public host; Traefik also emits its own headers (see
# traefik/dynamic_conf.yml) — keep the two in sync.
#HSTS_ENABLED=false
#CONTENT_SECURITY_POLICY_ENABLED=false
#HSTS_MAX_AGE=31536000
#HSTS_INCLUDE_SUBDOMAINS=true
#CONTENT_SECURITY_POLICY=

# ── Observability — Prometheus metrics ────────────────────────────────────────
METRICS_ENABLED=true
METRICS_GROUPS=all             # all | comma list of traffic,performance,reliability,health
# Optional static bearer credential for the /prompt/metrics scrape endpoint.
# Unset = network-isolation only. Set to have Prometheus present it as a Bearer.
#METRICS_SCRAPE_CREDENTIAL=changethis
# Optional credential for the deep /health detail body (X-Internal-Token).
# Unset = only the shallow {"status": ...} is returned (fail-closed).
# MUST NOT equal PRIVATE_API_SECRET (fatal startup error on reuse).
#HEALTH_DETAIL_CREDENTIAL=changethis
