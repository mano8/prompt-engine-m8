# Copy to auth.env — auth_user_service complete configuration (RS256 + hardened).
#
# This stack uses env-file secrets (no Vault). All secrets must be filled in here.
# Generate secret keys (32+ chars, upper, lower, digit, non-alphanumeric):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"

# Docker/K8s secret files: inherited from auth-sdk-m8 CommonSettings.
# For any secret field, set <FIELD>_FILE=/run/secrets/<name> instead of putting
# the plaintext value in this env file (for example DB_PASSWORD_FILE).
# The pointed file is stripped and used as the field value; missing files fail closed.

# ── Identity ──────────────────────────────────────────────────────────────────
DOMAIN=localhost
ENVIRONMENT=local
PROJECT_NAME=MyAuthService
STACK_NAME=my-auth-service

# ── API & docs ────────────────────────────────────────────────────────────────
API_PREFIX=/user
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true
# Explicitly enable docs in ENVIRONMENT=production (auth-sdk-m8 >= 0.7.3). Default: off.
# Only for public/open-source APIs. Emits a startup warning when enabled.
#SERVE_DOCS_IN_PRODUCTION=false

# ── CORS / Frontend ───────────────────────────────────────────────────────────
BACKEND_HOST=http://127.0.0.1:9000
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:9000

# ── Host header allowlist (auth-sdk-m8 >= 1.2) ───────────────────────────────
# Optional in local/dev. Set in production/strict mode to enable
# TrustedHostMiddleware and reject unexpected Host headers. Include every host
# used through Traefik plus Docker DNS names used by in-cluster callers.
#ALLOWED_HOSTS=localhost,127.0.0.1,auth_user_service

# ── Service role ──────────────────────────────────────────────────────────────
AUTH_SERVICE_ROLE=issuer

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# DB_USER must match AUTH_DB_USER in .env (the user created by init-db.sh).
# DB_PASSWORD must match AUTH_DB_PASSWORD in .env.
SELECTED_DB=Postgres
DB_HOST=m8_db
DB_PORT=5432
DB_DATABASE=auth_db
DB_USER=changethis_auth_user
# Password: >= 8 chars, with upper, lower, digit, and special char (no spaces).
DB_PASSWORD=changethis

# ── Redis ─────────────────────────────────────────────────────────────────────
# REDIS_PASSWORD must match REDIS_PASSWORD in .env.
REDIS_HOST=redis_cache
REDIS_PORT=6379
REDIS_USER=auth
# Password: >= 8 chars, with upper, lower, digit, and special char (no spaces).
REDIS_PASSWORD=changethis

# ── RS256 asymmetric signing — keys volume-mounted from ./keys:/opt/keys:ro ──
ACCESS_TOKEN_ALGORITHM=RS256
REFRESH_TOKEN_ALGORITHM=HS256
ACCESS_PRIVATE_KEY_FILE=/opt/keys/private.pem
ACCESS_PUBLIC_KEY_FILE=/opt/keys/public.pem
# Optional: stable kid for JWKS (auto-derived from key fingerprint if unset).
ACCESS_KEY_ID=changethis_hex_kid
REFRESH_SECRET_KEY=changethis
#REFRESH_SECRET_KEY_OLD=
TOKEN_MODE=stateful
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# ── Token boundary claims — REQUIRED under secure-by-default ──────────────────
# auth-sdk-m8 >= 1.0.0 turns TOKEN_STRICT_VALIDATION on by default: the service
# fails closed at boot unless both are set, and every validator requires an exact
# iss/aud match. Use identical values in this auth service and every consumer.
# Opt out (legacy/local only) with TOKEN_STRICT_VALIDATION=false.
TOKEN_ISSUER=https://auth.example.com
TOKEN_AUDIENCE=https://media.example.com

# ── Auth-service-only secrets ─────────────────────────────────────────────────
# Secrets below: passwords >= 8 chars; PRIVATE_API_SECRET / SESSION_SECRET /
# TOKENS_ENCRYPTION_KEY >= 32 chars — all need upper, lower, digit, special char.
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis
PRIVATE_API_SECRET=changethis
# Per-consumer credential registry (9.1 issuer side — fa-auth-m8 >= 1.0.0, REQUIRED).
# The bundled issuer runs the per-consumer model: map consumer ids to their own
# hashed secrets + scope list. When set, each consumer sends X-Internal-Client
# + X-Internal-Token; routes are scope-gated (deny-by-default).
# The legacy single-secret PRIVATE_API_SECRET gate is retired, so this registry is
# required — without it every private call fails closed (401).
# Format: {"<client-id>": {"secret": "<plaintext-or-sha256$encoded>", "scopes": ["introspection","event-stream"]}}
# The secret must match the consumer's PRIVATE_API_SECRET bootstrap credential.
PRIVATE_API_CONSUMERS={"media-service":{"secret":"changethis","scopes":["introspection","event-stream"]}}
# Signs the OAuth/session state cookie — REQUIRED (SecretStr, no default; boot
# fails closed without it). Use a strong unique value, never reused elsewhere.
SESSION_SECRET=changethis
TOKENS_ENCRYPTION_KEY=changethis

# ── Event signing — auth-sdk-m8 1.0.0 boot validator (fail-closed when enabled) ──
# EVENT_SIGNING_ENABLED defaults to true; boot fails closed without a strong key.
# Use the same EVENT_SIGNING_KEY here and in every consumer (media.env). SSE
# event-stream payloads (below) are HMAC-SHA256 signed with this key.
EVENT_SIGNING_ENABLED=true
EVENT_SIGNING_KEY=changethis

# ── Auth event stream — SSE bridge on the private API (fa-auth publisher) ──────
# Exposes GET /user/private/v1/events/stream so consumers (media_service) can
# evict their validation cache early on session-revoked / user-deleted events.
# Best-effort cache-eviction accelerator; the JTI blacklist stays authoritative.
EVENT_STREAM_ENABLED=true
EVENT_STREAM_BUFFER_SIZE=256
EVENT_STREAM_HEARTBEAT_SECONDS=15
EVENT_STREAM_MAX_QUEUE=64

# ── Hardened degradation policy ───────────────────────────────────────────────
# AUTH_STRICT_MODE overrides all per-control modes to fail_closed.
# Combined with the explicit fail_closed settings below, any Redis outage
# returns 503 rather than degrading silently.
AUTH_STRICT_MODE=true
RATE_LIMIT_FAILURE_MODE=fail_closed
ACCESS_REVOCATION_FAILURE_MODE=fail_closed
#REFRESH_VALIDATION_FAILURE_MODE=fail_closed
#SESSION_WRITE_FAILURE_MODE=fail_closed

# ── Rate limiting (optional) ──────────────────────────────────────────────────
# Defaults shown. Warn at startup if effective rate exceeds 5 req/min (login)
# or 20 req/min (refresh).
#LOGIN_RATE_LIMIT_REQUESTS=5
#LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
#REFRESH_RATE_LIMIT_REQUESTS=10
#REFRESH_RATE_LIMIT_WINDOW_MINUTES=5

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_GROUPS=all

# Optional bearer credential for /metrics. Leave unset to rely on the internal
# network boundary; if set, configure Prometheus to send the same bearer token.
#METRICS_SCRAPE_CREDENTIAL=changethis

# # ── Optional: Google OAuth ───────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Chrome extension / native-app OAuth (optional) ────────────────────────────
# Fixed backend callback URI — must match Google Console exactly.
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/google-auth/oauth-callback/

# URI schemes accepted as redirect_target at /google-api/login-url/ (default shown).
# OAUTH_ALLOWED_REDIRECT_SCHEMES=chrome-extension://

# Optional: lock to specific extension IDs (empty = open public-client model).
# OAUTH_ALLOWED_REDIRECT_PREFIXES=chrome-extension://abc123def456.../

# Scheme-level CORS — required for Chrome extension fetch() calls.
# CORS_ALLOWED_ORIGIN_SCHEMES=chrome-extension://

# ── Proxy trust (optional) ───────────────────────────────────────────────────
# Number of trusted reverse-proxy hops in front of this service.
# Used to extract the real client IP from X-Forwarded-For.
# Set to 1 for a single Traefik instance; 0 for no proxy (direct access).
#TRUSTED_PROXY_COUNT=1

# ── Response security headers (auth-sdk-m8 >= 1.2.1, three tiers) ─────────────
# Tier 1 (X-Content-Type-Options, X-Frame-Options) is always on; tier 2
# (Referrer-Policy, Permissions-Policy) applies on the production gate. Tier 3
# below is browser-persisted and hard to reverse (HSTS poisons a host's HTTPS
# cache for its full max-age), so it is express opt-in, defaults to off, and is
# NEVER emitted on a local stack even when enabled. Enable only on a
# TLS-terminated public host.
#HSTS_ENABLED=false
#CONTENT_SECURITY_POLICY_ENABLED=false
#HSTS_MAX_AGE=31536000
#HSTS_INCLUDE_SUBDOMAINS=true
#CONTENT_SECURITY_POLICY=
