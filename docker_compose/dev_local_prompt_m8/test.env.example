# security-tests-m8 live-test runner configuration for the stack in:
#   /workspace/prompt-engine-m8/docker_compose/dev_local_prompt_m8
#
# Copy to test.env and replace every `changethis` before running the suite.
# Install the runner first: pip install --upgrade security-tests-m8
# This targets the prompt_engine_service consumer (API_PREFIX=/prompt) fronted by
# the fa-auth-m8 issuer (/user). The combined stack also runs media-service; add
# "media" to LIVE_TEST_SVC_BASES / LIVE_TEST_PROTECTED_ENDPOINTS to test it too.

# ── Auth issuer ───────────────────────────────────────────────────────────────
LIVE_TEST_AUTH_BASE=http://localhost:9000/user
# Internal service-to-service entrypoint that exposes /private/*. The public edge
# blocks /private (Traefik -> 404), so the F06 per-consumer legacy-shape check
# targets this URL. Falls back to LIVE_TEST_AUTH_BASE when unset.
LIVE_TEST_INTERNAL_AUTH_BASE=http://localhost:9000/user
LIVE_TEST_AUTH_HEALTH_URL=http://localhost:9000/user/health/

# ── Service under test (prompt-engine) ────────────────────────────────────────
LIVE_TEST_SVC_BASE=http://localhost:9000/prompt
LIVE_TEST_SVC_BASES={"prompt":"http://localhost:9000/prompt"}
LIVE_TEST_DEFAULT_SVC=prompt

# ── Dedicated test-only superuser ─────────────────────────────────────────────
# Must be pre-created in the target stack. Do NOT use FIRST_SUPERUSER /
# FIRST_SUPERUSER_PASSWORD from auth.env — the preflight refuses that.
LIVE_TEST_ADMIN_EMAIL=changethis
LIVE_TEST_ADMIN_PASSWORD=changethis

# ── Private-API opt-in checks ─────────────────────────────────────────────────
# The prompt consumer's bootstrap credential (== PRIVATE_API_SECRET in prompt.env
# and its entry in auth.env's PRIVATE_API_CONSUMERS). Enables the F06
# legacy-detection check together with the client id below.
LIVE_TEST_PRIVATE_API_SECRET=changethis
LIVE_TEST_PRIVATE_API_CLIENT_ID=prompt-engine-service
# Deep /health detail credential. fa-auth-m8 gates the detail body (token mode,
# Redis/DB) on a dedicated HEALTH_DETAIL_CREDENTIAL via X-Internal-Token,
# decoupled from PRIVATE_API_SECRET (must differ from it). Opt-in/fail-closed on
# the stack; set it to match once enabled in prompt.env. Without it,
# require_redis and require_token_mode suites skip with an explicit reason.
# LIVE_TEST_HEALTH_DETAIL_CREDENTIAL=changethis
# Real REFRESH_SECRET_KEY (from prompt.env) — enables the refresh-secret leak
# check; leave unset to skip it.
LIVE_TEST_REFRESH_SECRET_KEY=changethis

# ── Runner behaviour ──────────────────────────────────────────────────────────
LIVE_TEST_TIMEOUT=10
LIVE_TEST_FAIL_FAST_PREFLIGHT=true
LIVE_TEST_FORBID_BOOTSTRAP_SUPERUSER=true
# Authenticated GET endpoints of prompt_engine_service with no required path
# params (each must return 200 for the admin token, 401/403 without a token).
# Paths are relative to the /prompt API prefix. Resource-scoped routes
# (e.g. /category/get/{item_id}/) and mutating routes are excluded.
LIVE_TEST_PROTECTED_ENDPOINTS={"prompt":["/category/","/dashboard/users/activity/","/dashboard/users/activity/current/","/prompt-block/","/prompt-template/"]}

# ── Public TLS entrypoint ─────────────────────────────────────────────────────
LIVE_TEST_PUBLIC_BASE=https://localhost:4430
LIVE_TEST_PUBLIC_TLS_VERIFY=false

# ── Stack roots (asymmetric key-leak checks read keys/ from here) ─────────────
LIVE_TEST_REPO_ROOT=/workspace/prompt-engine-m8/docker_compose/dev_local_prompt_m8
LIVE_TEST_DEPLOYMENT_ROOT=/workspace/prompt-engine-m8/docker_compose/dev_local_prompt_m8
HARDENED_M8_STACK_ROOT=/workspace/prompt-engine-m8/docker_compose/dev_local_prompt_m8
