# security-tests-m8 live configuration for:
# /workspace/media-service-m8/docker_compose/dev_local_media_m8
# you need to install security-tests-m8 in your python environment
# to run the tests.

LIVE_TEST_AUTH_BASE=http://localhost:9000/user
# Internal service-to-service entrypoint that exposes /private/* . The public
# edge blocks /private (Traefik -> 404), so the F06 per-consumer legacy-shape
# check targets this URL. Falls back to LIVE_TEST_AUTH_BASE when unset.
LIVE_TEST_INTERNAL_AUTH_BASE=http://localhost:9000/user
LIVE_TEST_AUTH_HEALTH_URL=http://localhost:9000/user/health/
LIVE_TEST_SVC_BASE=http://localhost:9000/media
LIVE_TEST_SVC_BASES={"media":"http://localhost:9000/media"}
LIVE_TEST_DEFAULT_SVC=media

# Dedicated test-only superuser. Do not use FIRST_SUPERUSER from auth.env.
LIVE_TEST_ADMIN_EMAIL=changethis
LIVE_TEST_ADMIN_PASSWORD=changethis
LIVE_TEST_PRIVATE_API_SECRET=changethis
LIVE_TEST_PRIVATE_API_CLIENT_ID=media-service
# Deep /health detail credential. fa-auth-m8 >= 1.0.0 gates the detail body
# (token mode, Redis/DB) on a dedicated HEALTH_DETAIL_CREDENTIAL via
# X-Internal-Token, decoupled from PRIVATE_API_SECRET (must differ from it).
# Opt-in/fail-closed on the stack; set this to match once enabled in auth.env.
# Without it, require_redis and require_token_mode suites skip with an explicit
# reason instead of running blind on defaults.
# LIVE_TEST_HEALTH_DETAIL_CREDENTIAL=changethis
LIVE_TEST_REFRESH_SECRET_KEY=changethis

LIVE_TEST_TIMEOUT=10
LIVE_TEST_FAIL_FAST_PREFLIGHT=true
LIVE_TEST_FORBID_BOOTSTRAP_SUPERUSER=true
LIVE_TEST_PROTECTED_ENDPOINTS={"media":["/category/","/dashboard/users/activity/","/dashboard/users/activity/current/","/v1/objects","/v1/presets","/v1/admin/storage/stats","/v1/admin/uploads/stale","/v1/admin/maintenance/orphans","/v1/admin/subscriptions"]}
LIVE_TEST_PUBLIC_BASE=https://localhost:4430
LIVE_TEST_PUBLIC_TLS_VERIFY=false
LIVE_TEST_REPO_ROOT=/workspace/media-service-m8/docker_compose/dev_local_media_m8
LIVE_TEST_DEPLOYMENT_ROOT=/workspace/media-service-m8/docker_compose/dev_local_media_m8
HARDENED_M8_STACK_ROOT=/workspace/media-service-m8/docker_compose/dev_local_media_m8
