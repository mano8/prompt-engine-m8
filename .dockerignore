# ---- compose runtime secrets ------------------------------------------------
# Non-example env files in any compose stack directory
docker_compose/**/.env
docker_compose/**/auth.env
docker_compose/**/api.env
docker_compose/**/test.env
docker_compose/**/grafana.env

# Generated signing keys and TLS private/public key material
docker_compose/**/keys/
docker_compose/**/traefik/certs/
**/*.pem
**/*.key
**/*.crt

# ---- compose runtime data ---------------------------------------------------
docker_compose/**/db_data/
docker_compose/**/redis/
docker_compose/**/grafana/data/
docker_compose/**/prometheus/data/
docker_compose/**/vault/data/

# ---- python development artifacts -------------------------------------------
.venv/
**/__pycache__/
**/*.pyc
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
coverage.xml

# ---- local-only config -------------------------------------------------------
CLAUDE.md
.claude/
